{
  "permissions": {
    "allow": [
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git push:*)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(curl:*)",
      "Bash(wc:*)",
      "Bash(python3:*)",
      "Bash(node:*)",
      "Bash(set +H:*)",
      "Bash(ls:*)",
      "Bash(cat:*)",
      "Bash(head:*)",
      "Bash(tail:*)",
      "Bash(find:*)",
      "Bash(grep:*)",
      "Edit",
      "Write",
      "Read",
      "Glob",
      "Grep",
      "WebSearch",
      "WebFetch",
      "Agent"
    ],
    "deny": [
      "Edit(**/.env)",
      "Edit(**/.env.*)",
      "Write(**/.env)",
      "Write(**/.env.*)",
      "Edit(**/.netlify/credential*)",
      "Write(**/.netlify/credential*)",
      "Edit(**/package-lock.json)",
      "Write(**/package-lock.json)"
    ]
  }
}
